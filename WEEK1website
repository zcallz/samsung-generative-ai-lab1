<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Analyst | Portfolio</title>
    <!-- Tailwind CSS for rapid styling (Vibe Coding) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* Custom Neon & Dark Theme Styles */
        body {
            background-color: #0f172a; /* Dark slate background */
            /* Abstract technology background glow effect */
            background-image: radial-gradient(circle at 50% 0%, #1e3a8a 0%, #0f172a 60%);
            color: #e2e8f0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .neon-glow {
            text-shadow: 0 0 15px rgba(59, 130, 246, 0.8);
        }
        
        .card-glow {
            box-shadow: 0 0 40px -10px rgba(59, 130, 246, 0.4);
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center p-6">

    <!-- Main Portfolio Card -->
    <div class="bg-slate-800/60 backdrop-blur-lg border border-blue-500/30 rounded-3xl p-10 max-w-3xl w-full text-center card-glow transition-all duration-500 hover:border-blue-400/60">
        
        <!-- Profile Picture (Placeholder matching the prompt) -->
        <div class="relative w-40 h-40 mx-auto mb-6">
            <div class="absolute inset-0 rounded-full bg-blue-500 blur-md opacity-50 animate-pulse"></div>
            <!-- Gorseli profesyonel bir profil fotagrafi ile degistirdim -->
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" 
                 alt="Professional Profile" 
                 class="relative w-full h-full rounded-full object-cover border-4 border-blue-500 z-10">
        </div>

        <!-- Role -->
        <h1 class="text-4xl font-extrabold text-white mb-3 neon-glow tracking-tight">Data Analyst</h1>
        <p class="text-blue-400 text-xl font-semibold mb-8 flex items-center justify-center gap-2">
            <i class="fa-solid fa-chart-pie"></i> Turning Data into Insights
        </p>

        <p class="text-slate-300 text-lg mb-10 leading-relaxed max-w-2xl mx-auto">
            I specialize in transforming raw, complex data into meaningful stories. By leveraging modern analytical tools, I help organizations make data-driven decisions and uncover hidden opportunities.
        </p>

        <!-- Strengths Section -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <!-- Strength 1 -->
            <div class="bg-slate-900/80 p-6 rounded-2xl border border-blue-900/50 hover:border-blue-500/50 transition-colors group">
                <i class="fa-solid fa-chart-line text-blue-500 text-4xl mb-4 group-hover:scale-110 transition-transform"></i>
                <h3 class="text-xl font-bold text-white mb-2">Data Visualization</h3>
                <p class="text-sm text-slate-400">Creating clear, impactful dashboards and reports to communicate trends.</p>
            </div>
            
            <!-- Strength 2 -->
            <div class="bg-slate-900/80 p-6 rounded-2xl border border-blue-900/50 hover:border-blue-500/50 transition-colors group">
                <i class="fa-solid fa-database text-blue-500 text-4xl mb-4 group-hover:scale-110 transition-transform"></i>
                <h3 class="text-xl font-bold text-white mb-2">Data Processing</h3>
                <p class="text-sm text-slate-400">Efficiently extracting, cleaning, and structuring large datasets (SQL/Python).</p>
            </div>

            <!-- Strength 3 -->
            <div class="bg-slate-900/80 p-6 rounded-2xl border border-blue-900/50 hover:border-blue-500/50 transition-colors group">
                <i class="fa-solid fa-magnifying-glass-chart text-blue-500 text-4xl mb-4 group-hover:scale-110 transition-transform"></i>
                <h3 class="text-xl font-bold text-white mb-2">Statistical Analysis</h3>
                <p class="text-sm text-slate-400">Applying statistical methods to identify correlations and drive strategy.</p>
            </div>
        </div>

        <!-- Social Links -->
        <div class="flex justify-center gap-8 border-t border-slate-700/50 pt-8 mt-4">
            <a href="#" class="text-slate-400 hover:text-blue-400 hover:scale-110 transition-all text-3xl">
                <i class="fa-brands fa-github"></i>
            </a>
            <a href="#" class="text-slate-400 hover:text-blue-400 hover:scale-110 transition-all text-3xl">
                <i class="fa-brands fa-linkedin"></i>
            </a>
            <a href="#" class="text-slate-400 hover:text-blue-400 hover:scale-110 transition-all text-3xl">
                <i class="fa-solid fa-envelope"></i>
            </a>
        </div>
    </div>

    <!-- Background Data Nodes Effect (Decorative) -->
    <div class="fixed top-20 left-20 w-32 h-32 bg-blue-600/20 rounded-full blur-[80px] -z-10"></div>
    <div class="fixed bottom-20 right-20 w-48 h-48 bg-cyan-600/10 rounded-full blur-[100px] -z-10"></div>

</body>
</html>
